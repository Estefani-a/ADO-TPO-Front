# --- Desarrollo con "npm run dev" (recomendado) ---
# El proxy de Vite reenvía /api/* al backend. Cambiá solo el host/puerto de tu API.
VITE_PROXY_TARGET=http://localhost:8080

# Si VITE_API_BASE está vacío, las peticiones van al mismo origen que el front
# (p. ej. http://localhost:5173/api/... → proxy → VITE_PROXY_TARGET).
# Si lo definís, fetch usa esa URL absoluta (útil sin proxy o build servido aparte).
# VITE_API_BASE=

# Ejemplo sin proxy (misma máquina, otro puerto):
# VITE_API_BASE=http://localhost:8080

# Logs de API en consola del navegador (URL, headers, payload, respuesta).
# En `npm run dev` ya están activos por defecto. En preview/prod: true para forzar, false para apagar.
# VITE_API_DEBUG=true
# VITE_API_DEBUG=false
